{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Verona",
  "scopeName": "source.verona",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#numbers" },
    { "include": "#shape-definition" },
    { "include": "#class-definition" },
    { "include": "#function-definition" },
    { "include": "#keywords" },
    { "include": "#builtin-types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.verona",
          "match": "//.*$"
        },
        {
          "name": "comment.block.verona",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#comments" }
          ]
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "comment": "Raw string with triple single quotes",
          "name": "string.quoted.raw.triple.verona",
          "begin": "'''\"",
          "end": "\"'''",
          "patterns": []
        },
        {
          "comment": "Raw string with double single quotes",
          "name": "string.quoted.raw.double.verona",
          "begin": "''\"",
          "end": "\"''",
          "patterns": []
        },
        {
          "comment": "Raw string with single quotes",
          "name": "string.quoted.raw.single.verona",
          "begin": "'\"",
          "end": "\"'",
          "patterns": []
        },
        {
          "comment": "Regular escaped string",
          "name": "string.quoted.double.verona",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "include": "#string-escapes" }
          ]
        }
      ]
    },

    "string-escapes": {
      "patterns": [
        {
          "name": "constant.character.escape.verona",
          "match": "\\\\[abfnrtv\\\\'\"?]"
        },
        {
          "name": "constant.character.escape.hex.verona",
          "match": "\\\\x[0-9a-fA-F]+"
        },
        {
          "name": "constant.character.escape.unicode.verona",
          "match": "\\\\u[0-9a-fA-F]{4}"
        },
        {
          "name": "constant.character.escape.unicode-long.verona",
          "match": "\\\\U[0-9a-fA-F]{8}"
        },
        {
          "name": "constant.character.escape.octal.verona",
          "match": "\\\\[0-7]{1,3}"
        },
        {
          "name": "invalid.illegal.unknown-escape.verona",
          "match": "\\\\."
        }
      ]
    },

    "characters": {
      "patterns": [
        {
          "comment": "Character literal with escape",
          "name": "constant.character.verona",
          "match": "'\\\\(x[0-9a-fA-F]+|u[0-9a-fA-F]{4}|U[0-9a-fA-F]{8}|[0-7]{1,3}|[abfnrtv\\\\'\"])'"
        },
        {
          "comment": "Simple character literal",
          "name": "constant.character.verona",
          "match": "'[^\\\\']'"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "comment": "Hex float literal",
          "name": "constant.numeric.float.hex.verona",
          "match": "\\b0x[_0-9a-fA-F]+\\.[_0-9a-fA-F]+(?:p[+-]?[_0-9]+)?\\b"
        },
        {
          "comment": "Decimal float literal",
          "name": "constant.numeric.float.decimal.verona",
          "match": "\\b[0-9][_0-9]*\\.[0-9][_0-9]*(?:e[+-]?[0-9][_0-9]*)?\\b"
        },
        {
          "comment": "Binary integer literal",
          "name": "constant.numeric.integer.binary.verona",
          "match": "\\b0b[_01]+\\b"
        },
        {
          "comment": "Octal integer literal",
          "name": "constant.numeric.integer.octal.verona",
          "match": "\\b0o[_0-7]+\\b"
        },
        {
          "comment": "Hex integer literal",
          "name": "constant.numeric.integer.hex.verona",
          "match": "\\b0x[_0-9a-fA-F]+\\b"
        },
        {
          "comment": "Decimal integer literal",
          "name": "constant.numeric.integer.decimal.verona",
          "match": "\\b[0-9][_0-9]*\\b"
        }
      ]
    },

    "shape-definition": {
      "patterns": [
        {
          "comment": "Shape declaration: 'shape name'",
          "match": "\\b(shape)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.shape.verona" },
            "2": { "name": "entity.name.type.shape.verona" }
          }
        }
      ]
    },

    "class-definition": {
      "patterns": [
        {
          "comment": "Class definition: bare name + optional type params, followed by newline then {",
          "match": "^([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\[[^\\]]*\\])?\\s*$",
          "captures": {
            "1": { "name": "entity.name.type.class.verona" }
          }
        }
      ]
    },

    "function-definition": {
      "patterns": [
        {
          "comment": "ref function definition",
          "match": "^(\\s*)(ref)\\s+([a-zA-Z_][a-zA-Z0-9_]*|[!#$%&*+\\-/<=>?@\\\\^`|~]+)\\s*(?=\\()",
          "captures": {
            "2": { "name": "keyword.other.ref.verona" },
            "3": { "name": "entity.name.function.verona" }
          }
        },
        {
          "comment": "Function/method definition: name(params): rettype or name(params)",
          "match": "^(\\s*)([a-zA-Z_][a-zA-Z0-9_]*|[!#$%&*+\\-/<=>?@\\\\^`|~]+)(?:\\s*\\[[^\\]]*\\])?\\s*(?=\\()",
          "captures": {
            "2": { "name": "entity.name.function.verona" }
          }
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "comment": "Control flow keywords",
          "name": "keyword.control.verona",
          "match": "\\b(if|else|while|for|match|when|break|continue|return|raise)\\b"
        },
        {
          "comment": "Declaration keywords",
          "name": "keyword.declaration.verona",
          "match": "\\b(let|var|use|shape|new)\\b"
        },
        {
          "comment": "Constraint keyword",
          "name": "keyword.other.where.verona",
          "match": "\\b(where)\\b"
        },
        {
          "comment": "Ref keyword (function modifier)",
          "name": "keyword.other.ref.verona",
          "match": "\\b(ref)\\b"
        },
        {
          "comment": "Init keyword (FFI use blocks)",
          "name": "keyword.other.init.verona",
          "match": "\\b(init)\\b"
        }
      ]
    },

    "builtin-types": {
      "patterns": [
        {
          "comment": "Integer types",
          "name": "support.type.primitive.verona",
          "match": "\\b(i8|i16|i32|i64|ilong|isize|u8|u16|u32|u64|ulong|usize)\\b"
        },
        {
          "comment": "Float types",
          "name": "support.type.primitive.verona",
          "match": "\\b(f32|f64)\\b"
        },
        {
          "comment": "Other built-in types",
          "name": "support.type.builtin.verona",
          "match": "\\b(bool|string|none|nomatch|any|ptr|array|ref|cown|callback|dyn|arrayiter)\\b"
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "comment": "Boolean literals",
          "name": "constant.language.boolean.verona",
          "match": "\\b(true|false)\\b"
        },
        {
          "comment": "Self in type position",
          "name": "variable.language.self.verona",
          "match": "\\b(self)\\b"
        },
        {
          "comment": "Discard",
          "name": "variable.language.discard.verona",
          "match": "\\b_\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "comment": "Arrow operator (lambda, function type)",
          "name": "keyword.operator.arrow.verona",
          "match": "->"
        },
        {
          "comment": "Triple colon (FFI/builtin call)",
          "name": "keyword.operator.ffi.verona",
          "match": ":::"
        },
        {
          "comment": "Double colon (scope resolution / array literal)",
          "name": "keyword.operator.scope.verona",
          "match": "::"
        },
        {
          "comment": "Comparison operators",
          "name": "keyword.operator.comparison.verona",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "comment": "Power operator",
          "name": "keyword.operator.arithmetic.verona",
          "match": "\\*\\*"
        },
        {
          "comment": "Arithmetic operators",
          "name": "keyword.operator.arithmetic.verona",
          "match": "[+\\-*/%]"
        },
        {
          "comment": "Shift operators",
          "name": "keyword.operator.bitwise.verona",
          "match": "<<|>>"
        },
        {
          "comment": "Logical/bitwise operators",
          "name": "keyword.operator.logical.verona",
          "match": "[&|^!~]"
        },
        {
          "comment": "Assignment",
          "name": "keyword.operator.assignment.verona",
          "match": "="
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "comment": "Spread/splat",
          "name": "punctuation.vararg.verona",
          "match": "\\.\\.\\."
        },
        {
          "comment": "Dot accessor",
          "name": "punctuation.accessor.dot.verona",
          "match": "\\."
        },
        {
          "comment": "Colon (type annotation)",
          "name": "punctuation.separator.colon.verona",
          "match": ":"
        },
        {
          "comment": "Semicolon",
          "name": "punctuation.separator.semicolon.verona",
          "match": ";"
        },
        {
          "comment": "Comma",
          "name": "punctuation.separator.comma.verona",
          "match": ","
        },
        {
          "comment": "Hash (freeze)",
          "name": "punctuation.special.hash.verona",
          "match": "#"
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "comment": "Qualified type/module access: Name::name",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\s*(::)",
          "captures": {
            "1": { "name": "entity.name.type.verona" },
            "2": { "name": "keyword.operator.scope.verona" }
          }
        },
        {
          "comment": "General identifier",
          "name": "variable.other.verona",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
