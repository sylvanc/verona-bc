lib
  @set_exit_code = "set_exit_code"(i32): none

// Storing the wrong type through a ref to a typed var should fail at runtime.

func @main(): none var $val: i32
  $val = const i32 42
  $wrong = const bool true
  $r = ref $val
  // Store a bool through a ref to an i32 var — should fail.
  $prev = store $r $wrong
  $_ = ffi @set_exit_code($val)
  $_none = const none
  ret $_none
